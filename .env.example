# ── LLM Provider 配置 ──────────────────────────────────
# 提供商类型：openai | anthropic | google | deepseek | xai | openai-compatible
LLM_PROVIDER=openai-compatible

# API 密钥
LLM_API_KEY=sk-xxx

# 自定义 Base URL（代理 / 本地 / 第三方兼容端点）
LLM_BASE_URL=https://api.openai.com/v1

# 默认模型（Narrator 使用）
LLM_MODEL=gpt-4o-mini

# 可选：不同角色使用不同模型（不配置则复用默认模型）
# LLM_DIRECTOR_MODEL=gpt-4o
# LLM_VERIFIER_MODEL=gpt-4o-mini
# LLM_MEMORY_MODEL=gpt-4o-mini

# ── 服务器 ─────────────────────────────────────────────
PORT=3000

# ── 认证（可选） ───────────────────────────────────────
# AUTH_MODE=off|api_key|jwt（默认 off）
# AUTH_MODE=off
# API Key 模式：逗号分隔多个 key
# AUTH_API_KEYS=dev-key-1,dev-key-2
# JWT 模式：HMAC secret
# AUTH_JWT_SECRET=replace-with-strong-secret

# Profile 密钥加密（用于 LLM Profile API Key 入库加密）
APP_SECRETS_MASTER_KEY=replace-with-strong-secret

# 数据库路径（默认 data/tavern-headless.db）
# DATABASE_URL=data/tavern-headless.db

# 可选：限制进入 prompt 的历史楼层数（最近 N 层）
# 默认不限制；仅在长会话场景下按需开启
# CHAT_HISTORY_MAX_FLOORS=200

# 是否启用记忆系统（摘要注入 + 持久化）
# 启用后会在 prompt 中注入 [Memory Summary]，并将每轮摘要持久化到记忆表
# ENABLE_MEMORY=true

# 是否启用 SSE 流式聊天端点（/sessions/:id/respond/stream）
# 默认关闭，建议按需启用
# ENABLE_SSE_CHAT=true

# 是否启用 Prompt Dry-run 调试端点（/sessions/:id/respond/dry-run）
# 默认关闭（端点会返回 404）
# ENABLE_PROMPT_DRY_RUN=true

# 是否默认启用 MemoryConsolidator（可通过请求体 config.enableMemoryConsolidation 覆盖）
# 依赖 ENABLE_MEMORY=true
# ENABLE_MEMORY_CONSOLIDATION=true

# 可选：记忆注入衰减排序（更偏向最近更新的记忆）
# 依赖 ENABLE_MEMORY=true
# 半衰期（天），例如 7 表示每 7 天有效重要度减半
# MEMORY_INJECTION_DECAY_HALF_LIFE_DAYS=7
# 衰减因子下限（0-1），避免过旧记忆完全归零（默认 0.05）
# MEMORY_INJECTION_DECAY_MIN_FACTOR=0.05
# 使用哪个时间字段计算 age：updatedAt | createdAt（默认 updatedAt）
# MEMORY_INJECTION_DECAY_BY=updatedAt

# 可选：记忆维护任务（deprecate / purge）
# 依赖 ENABLE_MEMORY=true
# ENABLE_MEMORY_MAINTENANCE=true
# 维护任务运行间隔（分钟，默认 60）
# MEMORY_MAINTENANCE_INTERVAL_MINUTES=60
# 批处理大小（默认 500）
# MEMORY_MAINTENANCE_BATCH_SIZE=500
# summary 超过 N 天自动 deprecated（默认 30，设为 0 禁用）
# MEMORY_MAINTENANCE_DEPRECATE_SUMMARY_DAYS=30
# open_loop 超过 N 天自动 deprecated（默认 7，设为 0 禁用）
# MEMORY_MAINTENANCE_DEPRECATE_OPEN_LOOP_DAYS=7
# deprecated 且自上次更新后超过 N 天自动删除（默认 90，设为 0 禁用）
# 当前无独立 deprecatedAt；这里以 updatedAt 作为 deprecated 状态下的最后变更时间
# MEMORY_MAINTENANCE_PURGE_DEPRECATED_DAYS=90
# dry-run：仅统计不执行写入/删除（默认 false）
# MEMORY_MAINTENANCE_DRY_RUN=false

# ── MCP 工具集成 ────────────────────────────────────────
# 是否启用 MCP (Model Context Protocol) 客户端
# 启用后可通过 API 管理 MCP 服务器，并将其工具注册到 Tool Calling 系统
# ENABLE_MCP=true
