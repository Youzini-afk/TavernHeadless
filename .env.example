# ── LLM Provider 配置 ──────────────────────────────────
# 提供商类型：openai | anthropic | google | deepseek | xai | openai-compatible
LLM_PROVIDER=openai-compatible

# API 密钥
LLM_API_KEY=sk-xxx

# 自定义 Base URL（代理 / 本地 / 第三方兼容端点）
LLM_BASE_URL=https://api.openai.com/v1

# 默认模型（Narrator 使用）
LLM_MODEL=gpt-4o-mini

# 可选：不同角色使用不同模型（不配置则复用默认模型）
# LLM_DIRECTOR_MODEL=gpt-4o
# LLM_VERIFIER_MODEL=gpt-4o-mini
# LLM_MEMORY_MODEL=gpt-4o-mini

# 可选：服务端默认生成超时（毫秒，默认 60000）
# LLM_DEFAULT_TIMEOUT_MS=60000

# ── 服务器 ─────────────────────────────────────────────
PORT=3000

# ── 认证（可选） ───────────────────────────────────────
# AUTH_MODE=off|api_key|jwt（默认 off）
# AUTH_MODE=off
# API Key 模式：逗号分隔多个 key
# AUTH_API_KEYS=dev-key-1,dev-key-2
# 多账号 + API Key 模式：key:account_id 映射，逗号分隔
# ACCOUNT_MODE=multi 时必填
# AUTH_API_KEY_ACCOUNTS=dev-key-1:default-admin,dev-key-2:workspace-a
# JWT 模式：HMAC secret
# AUTH_JWT_SECRET=replace-with-strong-secret
# 多账号 + JWT 模式：账号 claim 字段名（默认 account_id）
# AUTH_JWT_ACCOUNT_CLAIM=account_id
# 多账号模式：single（默认）| multi
# ACCOUNT_MODE=single
# 注意：ACCOUNT_MODE=multi 不能与 AUTH_MODE=off 组合使用
# 认证后的角色和状态以数据库 account 行中的 role / status 为准
# JWT 的 role claim 只用于身份载荷，不直接授予管理员权限

# Profile 密钥加密（用于 LLM Profile API Key 入库加密）
APP_SECRETS_MASTER_KEY=replace-with-strong-secret

# 数据库路径（默认 data/tavern-headless.db）
# DATABASE_URL=data/tavern-headless.db
# DB_PATH=data/tavern-headless.db

# WebSocket 事件转发（默认开启；设为 false 可禁用 /ws）
# ENABLE_WEBSOCKET=true

# 可选：限制进入 prompt 的历史楼层数（最近 N 层）
# 默认不限制；仅在长会话场景下按需开启
# CHAT_HISTORY_MAX_FLOORS=200

# 是否启用记忆系统（摘要注入 + 持久化）
# 启用后会在 prompt 中注入 [Memory Summary]，并将每轮摘要持久化到记忆表
# ENABLE_MEMORY=true

# 是否启用 SSE 流式聊天端点（/sessions/:id/respond/stream）
# 默认关闭，建议按需启用
# ENABLE_SSE_CHAT=true

# 是否启用 Prompt Dry-run 调试端点（/sessions/:id/respond/dry-run）
# 默认关闭（端点会返回 404）
# ENABLE_PROMPT_DRY_RUN=true

# commit 的 SQLITE_BUSY / SQLITE_LOCKED 有限重试参数
# TURN_COMMIT_MAX_RETRIES=2
# TURN_COMMIT_RETRY_BASE_DELAY_MS=100

# 同一 session + branch 的生成并发策略：reject（默认）| queue
# 注意：该队列仍然只在当前进程内生效，不是跨实例共享队列
# GENERATION_QUEUE_MODE=reject

# queue 模式下的排队等待超时（毫秒，可选；默认沿用服务内 5000）
# GENERATION_QUEUE_TIMEOUT_MS=5000

# 是否默认启用 MemoryConsolidator（可通过请求体 config.enableMemoryConsolidation 覆盖）
# 依赖 ENABLE_MEMORY=true
# ENABLE_MEMORY_CONSOLIDATION=true
# 是否启用异步记忆入队主路径（Phase 2 切换开关）
# ENABLE_ASYNC_MEMORY_INGEST=true
# 是否启用 macro summary 压缩（Phase 4 切换开关）
# ENABLE_MACRO_COMPACTION=true
# 是否启用 micro/macro 双层摘要注入预算（Phase 4 切换开关）
# ENABLE_DUAL_SUMMARY_INJECTION=true

# 是否启用 deferred irreversible tool runtime 入口（默认 false）
# DEFERRED_IRREVERSIBLE_MCP_TOOLS 使用 `serverId/toolName`，逗号分隔
# ENABLE_DEFERRED_IRREVERSIBLE_TOOLS=true
# DEFERRED_IRREVERSIBLE_MCP_TOOLS=server-a/tool-x,server-b/tool-y

# 危险：script handler 会在主 API 进程内执行动态脚本。
# Beta3 默认关闭。只有在明确受信的本地 / 管理环境中才应手动打开。
# 开启后，/tools/definitions 的 script 创建、更新和重新启用才会放行，
# 并且 definition-backed script tools 才会进入会话运行时目录并可执行。
# ENABLE_UNSAFE_SCRIPT_HANDLER=true

# ── Client Data / Session State ─────────────────────────
# 是否启用 Client Data 与 Session State 相关路由（默认 false）
# 开启后会注册：
# - /client-data/*
# - /sessions/:sessionId/state/*
# - /sessions/:sessionId/session-state/*
# - /floors/:floorId/session-state/*
# ENABLE_CLIENT_DATA=true
# CLIENT_DATA_EXPIRATION_INTERVAL_MS=300000
# CLIENT_DATA_DOMAIN_PURGE_GRACE_PERIOD_MS=604800000
# CLIENT_DATA_DEFAULT_MAX_ITEM_SIZE_BYTES=1048576
# CLIENT_DATA_DEFAULT_QUOTA_MAX_ENTRIES=10000
# CLIENT_DATA_DEFAULT_QUOTA_MAX_BYTES=10485760
# CLIENT_DATA_MAX_DOMAINS_PER_ACCOUNT=64
# CLIENT_DATA_MAX_TOTAL_ENTRIES_PER_ACCOUNT=100000
# CLIENT_DATA_MAX_TOTAL_BYTES_PER_ACCOUNT=104857600

# 可选：记忆注入衰减排序（更偏向最近更新的记忆）
# 依赖 ENABLE_MEMORY=true
# 半衰期（天），例如 7 表示每 7 天有效重要度减半
# MEMORY_INJECTION_DECAY_HALF_LIFE_DAYS=7
# 衰减因子下限（0-1），避免过旧记忆完全归零（默认 0.05）
# MEMORY_INJECTION_DECAY_MIN_FACTOR=0.05
# 使用哪个时间字段计算 age：updatedAt | createdAt（默认 updatedAt）
# MEMORY_INJECTION_DECAY_BY=updatedAt

# 可选：记忆维护任务（deprecate / purge）
# 依赖 ENABLE_MEMORY=true
# ENABLE_MEMORY_MAINTENANCE=true
# 维护任务运行间隔（分钟，默认 60）
# MEMORY_MAINTENANCE_INTERVAL_MINUTES=60
# 批处理大小（默认 500）
# MEMORY_MAINTENANCE_BATCH_SIZE=500
# summary 超过 N 天自动 deprecated（默认 30，设为 0 禁用）
# MEMORY_MAINTENANCE_DEPRECATE_SUMMARY_DAYS=30
# open_loop 超过 N 天自动 deprecated（默认 7，设为 0 禁用）
# MEMORY_MAINTENANCE_DEPRECATE_OPEN_LOOP_DAYS=7
# deprecated 且自上次更新后超过 N 天自动删除（默认 90，设为 0 禁用）
# 当前无独立 deprecatedAt；这里以 updatedAt 作为 deprecated 状态下的最后变更时间
# MEMORY_MAINTENANCE_PURGE_DEPRECATED_DAYS=90
# dry-run：仅统计不执行写入/删除（默认 false）
# MEMORY_MAINTENANCE_DRY_RUN=false

# 可选：MemoryWorker 运行参数
# 默认值分别为：2000 / 120000 / 4 / 1000 / 30000 / 32
# MEMORY_WORKER_POLL_INTERVAL_MS=2000
# MEMORY_WORKER_LEASE_TTL_MS=120000
# MEMORY_WORKER_MAX_CONCURRENT_JOBS=4
# MEMORY_WORKER_RETRY_BASE_DELAY_MS=1000
# MEMORY_WORKER_MAX_RETRY_DELAY_MS=30000
# MEMORY_WORKER_CANDIDATE_SCAN_LIMIT=32
# 说明：
# - 开启 ENABLE_ASYNC_MEMORY_INGEST 时，ingest_turn / compact_macro 由 MemoryWorker 处理
# - 开启 ENABLE_MEMORY_MAINTENANCE 时，maintenance 也会统一进入 memory_job 队列
# - 手动 rebuild_scope / compact_macro 管理接口同样依赖后台 worker

# 可选：聊天导入 / 导出后台 worker 与产物配置
# ENABLE_CHAT_TRANSFER_WORKER=true
# RuntimeWorker 默认值分别为：2000 / 120000 / 1 / 1000 / 30000 / 32
# CHAT_TRANSFER_WORKER_POLL_INTERVAL_MS=2000
# CHAT_TRANSFER_WORKER_LEASE_TTL_MS=120000
# CHAT_TRANSFER_WORKER_MAX_CONCURRENT_JOBS=1
# CHAT_TRANSFER_WORKER_RETRY_BASE_DELAY_MS=1000
# CHAT_TRANSFER_WORKER_MAX_RETRY_DELAY_MS=30000
# CHAT_TRANSFER_WORKER_CANDIDATE_SCAN_LIMIT=32
# 产物目录默认 data/chat-transfer-artifacts
# CHAT_TRANSFER_ARTIFACT_DIR=data/chat-transfer-artifacts
# 聊天导入大小限制；路由默认回退值 5000000
# CHAT_IMPORT_MAX_BYTES=5000000
# 如果设置了同步导出阈值，超过后会改为要求异步导出；不设置则不启用阈值
# CHAT_EXPORT_SYNC_MAX_MESSAGES=200
# 导出产物 TTL（毫秒）；不设置则产物不自动过期
# CHAT_EXPORT_ARTIFACT_TTL_MS=86400000

# CORS（默认已允许本地 Vite 端口）
CORS_ORIGINS=*
CORS_CREDENTIALS=false

# ── MCP 工具集成 ────────────────────────────────────────
# 是否启用 MCP (Model Context Protocol) 客户端
# 启用后可通过 API 管理 MCP 服务器，并将其工具注册到 Tool Calling 系统
# ENABLE_MCP=true
