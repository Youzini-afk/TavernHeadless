{
  "name": "@tavern/api",
  "version": "0.2.0-beta.3",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "bench:history": "tsx scripts/benchmark-history.ts",
    "smoke": "tsx scripts/smoke-api.ts",
    "real-provider:regression": "tsx scripts/real-provider-regression.ts",
    "jobs:chat-transfer": "tsx src/chat-transfer-worker.ts",
    "memory:maintenance": "tsx scripts/memory-maintenance.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "openapi:export": "tsx scripts/export-openapi.ts"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@tavern/adapters-sillytavern": "workspace:*",
    "@tavern/core": "workspace:*",
    "@tavern/shared": "workspace:*",
    "better-sqlite3": "12.8.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.8.5",
    "nanoid": "^5.0.9",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
