{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@tavern/core": ["./packages/core/src/index.ts"],
      "@tavern/shared": ["./packages/shared/src/index.ts"],
      "@tavern/shared/types/*": ["./packages/shared/src/types/*"],
      "@tavern/adapters-sillytavern": ["./packages/adapters-sillytavern/src/index.ts"],
      "@tavern/sdk": ["./packages/official-integration-kit/sdk/src/index.ts"],
      "@tavern/client-helpers": ["./packages/official-integration-kit/client-helpers/src/index.ts"]
    }
  }
}
